# NutriAI - .env.example
# Copy this file to .env and fill in your keys
# Never commit .env to GitHub — only commit .env.example

# ── PostgreSQL (Neon) ──────────────────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connection Details
# Make sure connection pooling is ON
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Needs Inference API access (free tier works)
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Cloud Vision API ────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Vision API → Credentials
# Free tier: 1000 calls/month — more than enough for one-time menu setup
# If not set, OCR falls back to Tesseract automatically
GOOGLE_VISION_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gemini (optional — last resort nutrition fallback) ─────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Only used as Layer 5 in nutrition.py when all HF models fail
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangSmith observability (optional but recommended) ────────────────────────
# Get from: https://smith.langchain.com → Settings → API Keys
# Enables full tracing of all LangGraph agent runs
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nutriai
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
